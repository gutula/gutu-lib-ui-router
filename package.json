{
  "name": "gutu-lib-ui-router",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/ui-router build",
    "typecheck": "bun run --cwd framework/libraries/ui-router typecheck",
    "lint": "bun run --cwd framework/libraries/ui-router lint",
    "test": "bun run --cwd framework/libraries/ui-router test",
    "test:unit": "bun run --cwd framework/libraries/ui-router test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
